# Database & Cache Settings
DATABASE_URL=postgresql://ascend:ascend@localhost:5432/ascend
REDIS_URL=redis://localhost:6379

# Authentication Settings (JWT secrets should be at least 16 chars)
JWT_SECRET=changeme_at_least_16_chars
JWT_REFRESH_SECRET=changeme_at_least_16_chars

# LLM Provider Configuration (e.g. Anthropic, OpenAI, Groq, Ollama)
LLM_PROVIDER=anthropic
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2000

# Embedding Configuration (Using GitHub Models for free 1536-dim embeddings)
# Requires a GitHub Personal Access Token (PAT) set in EMBEDDING_API_KEY
EMBEDDING_BASE_URL=https://models.github.ai/inference
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Cloudinary Settings (Optional - for PDF uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Job Discovery (TinyFish - free at tinyfish.ai, no credit card required)
# Sign up at https://tinyfish.ai to get your API key
TINYFISH_API_KEY=

# General App Configuration
CLIENT_URL=http://localhost:5173
PORT=3001
REMINDER_DAYS_THRESHOLD=7
